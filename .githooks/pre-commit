#!/bin/bash
# Auto-incrementa la versión en index.html (vX.Y) y simulador-bot.html (vX.Y.Z)
# solo cuando el archivo está en el staging area.

bump_index() {
  local file="index.html"
  git diff --cached --name-only | grep -q "^$file$" || return
  local current
  current=$(grep -oP 'v\K[0-9]+\.[0-9]+(?=<)' "$file" | head -1)
  [ -z "$current" ] && return
  local major minor
  IFS='.' read -r major minor <<< "$current"
  local next="$major.$((minor + 1))"
  sed -i "s/v$current/v$next/" "$file"
  git add "$file"
  echo "  bumped $file: v$current → v$next"
}

bump_simulador() {
  local file="simulador-bot.html"
  git diff --cached --name-only | grep -q "^$file$" || return
  local current
  current=$(grep -oP 'v\K[0-9]+\.[0-9]+\.[0-9]+' "$file" | head -1)
  [ -z "$current" ] && return
  local major minor patch
  IFS='.' read -r major minor patch <<< "$current"
  local next="$major.$minor.$((patch + 1))"
  sed -i "s/v$current/v$next/" "$file"
  git add "$file"
  echo "  bumped $file: v$current → v$next"
}

bump_index
bump_simulador
